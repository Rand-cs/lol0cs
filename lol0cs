import ipaddress
import re
import time
from datetime import datetime

_R = os.path.dirname(os.path.realpath(__file__))
sys.path.insert(0, _R)

from core.guardian import verify_integrity as vfy, init_integrity as init_int, status as get_st
from core.scanner  import run_scan, is_alive, get_ip, ScanRes, P_PROFS
from core.probe    import grab
from core.render   import *

C_PORTS = [
    21, 22, 23, 25, 53, 80, 110, 111, 135, 137, 138, 139, 143,
    161, 389, 443, 445, 465, 514, 587, 636, 993, 995, 1433, 1521,
    2049, 2181, 2375, 3000, 3306, 3389, 5432, 5900, 5985, 6379,
    8000, 8080, 8443, 8888, 9000, 9090, 9200, 27017,
]

def p_ports(sp):
    sp = sp.strip().lower()
    if sp in ("top", "common", ""): return sorted(set(C_PORTS))
    if sp == "all": return list(range(1, 65536))

    pts = []
    for t in sp.split(","):
        t = t.strip()
        if not t: continue
        if "-" in t:
            l, h = t.split("-", 1)
            pts.extend(range(int(l), int(h) + 1))
        else:
            pts.append(int(t))
    return sorted({p for p in pts if 1 <= p <= 65535})

def p_tgts(rw):
    tgs = []
    for p in rw.split(","):
        p = p.strip()
        if not p: continue
        if "/" in p:
            try:
                n = ipaddress.ip_network(p, strict=False)
                tgs.extend(str(h) for h in n.hosts())
                continue
            except ValueError: pass
        
        m = re.match(r"^(\d+\.\d+\.\d+\.)(\d+)-(\d+)$", p)
        if m:
            px, l, h = m.group(1), int(m.group(2)), int(m.group(3))
            tgs.extend(f"{px}{i}" for i in range(l, h + 1))
            continue
            
        i = get_ip(p)
        if i: tgs.append(i)
        else: msg_er(f"cannot resolve: {p}")
    return tgs

def c_init(a):
    msg_in("initializing integrity manifest...")
    init_int(_R)

def c_ver(a):
    print(f"\n  {bld(cyn('LOL0CS'))}  network reconnaissance tool")
    print(f"  {dim('author  : LOUAA AL MITHEAB')}")
    print(f"  {dim('version : 1.0.0')}")
    print(f"  {dim('python  : ' + sys.version.split()[0])}\n")

def c_st(a):
    s = get_st(_R)
    show_stat(s)

def c_host(a):
    tgs = p_tgts(a.target)
    if not tgs:
        msg_er("no valid targets")
        sys.exit(1)

    vfy(_R)

    print()
    msg_in(f"host discovery on {len(tgs)} target(s)\n")

    up, dn = [], []
    for i in tgs:
        alv = is_alive(i, timeout=a.timeout)
        ss = grn("up") if alv else rd("down")
        print(f"  {i:<20}  {ss}")
        (up if alv else dn).append(i)

    print(dim(f"\n  {len(up)} up  |  {len(dn)} down\n"))

def c_probe(a):
    i = get_ip(a.target)
    if not i:
        msg_er(f"cannot resolve: {a.target}")
        sys.exit(1)

    vfy(_R)

    msg_in(f"probing {i}:{a.port} ...")
    r = grab(i, a.port, timeout=a.timeout)
    show_prb(i, a.port, r)

def c_scan(a):
    tgs = p_tgts(a.target)
    if not tgs:
        msg_er("no valid targets resolved")
        sys.exit(1)

    try:
        pts = p_ports(a.ports)
    except ValueError as e:
        msg_er(f"invalid port spec: {e}")
        sys.exit(1)

    if a.timing not in P_PROFS:
        msg_er(f"unknown timing profile: {a.timing}")
        sys.exit(1)

    vfy(_R)

    show_hdr(a.target, a.ports, a.timing, "connect", datetime.now().strftime("%Y-%m-%d %H:%M:%S"))

    tt = time.monotonic()
    ar = []
    to = 0

    for i in tgs:
        if not a.no_ping:
            msg_in(f"checking {i} ...")
            alv = is_alive(i, t=a.timeout)
            if not alv:
                msg_wn(f"{i}  down / no response")
                continue
        else:
            alv = True

        def plog(m):
            if not a.quiet: print(m)

        r = run_scan(i, pts, prof=a.timing, t=a.timeout, banner=not a.no_banner, rdns=not a.no_rdns, w=a.workers, log_cb=plog)
        ar.append(r)
        to += len(r.opens)

        if not a.quiet:
            show_host(r.ip, r.hostname, r.up, [p for p in r.ports if p["state"] == "open" or (a.show_all and p["state"] in ("closed", "filtered"))], r.t_scan)

    sum_up(len(tgs), len(ar), to, time.monotonic() - tt)

def main():
    p = argparse.ArgumentParser(prog="lol0cs", add_help=False, usage="lol0cs <command> [options]")
    s = p.add_subparsers(dest="cmd")

    s.add_parser("init", help="generate integrity manifest")
    s.add_parser("version", help="show version")
    s.add_parser("status", help="show integrity status")
    s.add_parser("help", help="show this help")

    ph = s.add_parser("host", help="host discovery only")
    ph.add_argument("target")
    ph.add_argument("--timeout", type=float, default=1.5)

    pp = s.add_parser("probe", help="detailed single-port probe")
    pp.add_argument("target")
    pp.add_argument("port", type=int)
    pp.add_argument("--timeout", type=float, default=3.0)

    ps = s.add_parser("scan", help="full port scan")
    ps.add_argument("target")
    ps.add_argument("-p", "--ports", default="top")
    ps.add_argument("-t", "--timing", default="normal", choices=list(P_PROFS.keys()))
    ps.add_argument("--timeout", type=float, default=2.0)
    ps.add_argument("--workers", type=int, default=60)
    ps.add_argument("--no-ping", action="store_true")
    ps.add_argument("--no-banner", action="store_true")
    ps.add_argument("--no-rdns", action="store_true")
    ps.add_argument("--show-all", action="store_true", help="include closed/filtered ports")
    ps.add_argument("-q", "--quiet", action="store_true")

    a = p.parse_args()

    dp = {
        "init": c_init, "version": c_ver, "status": c_st,
        "host": c_host, "probe": c_probe, "scan": c_scan,
    }

    if a.cmd == "help" or a.cmd not in dp:
        print(__doc__)
        sys.exit(0)

    dp[a.cmd](a)

if __name__ == "__main__":
    main()
